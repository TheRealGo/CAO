#!/usr/bin/env bash
set -euo pipefail

detect_session() {
  if [[ -n "${CAO_SESSION:-}" ]]; then
    printf '%s\n' "$CAO_SESSION"
    return
  fi

  if [[ -n "${TMUX:-}" ]]; then
    local current
    current="$(tmux display-message -p '#{session_name}' 2>/dev/null || true)"
    if [[ -n "$current" ]]; then
      printf '%s\n' "$current"
      return
    fi
  fi

  if command -v tmux >/dev/null 2>&1; then
    if tmux has-session -t CAO 2>/dev/null; then
      printf 'CAO\n'
      return
    fi
  fi

  printf 'CAO\n'
}

SESSION="$(detect_session)"
CODEX_BIN="${CODEX_BIN:-codex}"
CLAUDE_BIN="${CLAUDE_BIN:-claude}"
DEFAULT_HISTORY="${CAO_HISTORY:-4000}"
STATE_DIR="${CAO_STATE_DIR:-.cao}"
TARGETS_FILE="${CAO_TARGETS_FILE:-$STATE_DIR/targets.tsv}"
DASHBOARD_WIDTH="${CAO_DASHBOARD_WIDTH:-34}"
AUTO_COMPACT="${CAO_AUTO_COMPACT:-1}"
AUTO_COMPACT_THRESHOLD="${CAO_AUTO_COMPACT_THRESHOLD:-50}"
AUTO_COMPACT_COOLDOWN="${CAO_AUTO_COMPACT_COOLDOWN:-900}"
AUTO_COMPACT_INTERVAL="${CAO_AUTO_COMPACT_INTERVAL:-15}"
SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)/$(basename "${BASH_SOURCE[0]}")"

# Detect the supervisor's runner from environment so worker default mirrors it.
# Override with CAO_RUNNER or `cao add --runner ...`.
detect_runner() {
  if [[ -n "${CLAUDECODE:-}" ]] || [[ -n "${CLAUDE_CODE_ENTRYPOINT:-}" ]]; then
    printf 'claude\n'
  elif [[ -n "${CODEX_HOME:-}" ]] || [[ -n "${CODEX_SANDBOX_NETWORK_DISABLED:-}" ]]; then
    printf 'codex\n'
  else
    printf 'claude\n'
  fi
}
CAO_RUNNER="${CAO_RUNNER:-$(detect_runner)}"

usage() {
  cat <<'USAGE'
Usage:
  cao init [--session NAME]
  cao add DIRECTORY [--runner claude|codex] [--name NAME] [--resume] [--prompt TEXT] [--session NAME]
  cao register TARGET --runner claude|codex [--session NAME]
  cao unregister TARGET [--session NAME]
  cao list [--session NAME]
  cao capture [TARGET] [--lines N] [--session NAME]
  cao send TARGET TEXT [--enter|--no-enter] [--session NAME]
  cao attach [--session NAME]
  cao kill [--session NAME]

Targets are tmux targets such as:
  agent-a
  CAO:agent-a
  CAO:agent-a.0

Environment:
  CAO_SESSION   tmux session name, default: current tmux session or CAO
  CAO_RUNNER    default worker runner (claude|codex), default: auto-detected
  CLAUDE_BIN    Claude Code command, default: claude
  CODEX_BIN     Codex command, default: codex
  CAO_HISTORY   capture-pane history lines, default: 4000
  CAO_STATE_DIR registered external target state, default: .cao
  CAO_DASHBOARD_WIDTH dashboard pane width, default: 34
  CAO_AUTO_COMPACT auto-run /compact at safe boundaries, default: 1
  CAO_AUTO_COMPACT_THRESHOLD context percent threshold, default: 50
  CAO_AUTO_COMPACT_COOLDOWN seconds before retry per worker, default: 900
  CAO_AUTO_COMPACT_INTERVAL seconds between auto-compact sweeps, default: 15

Submit keys per runner (cao send picks the right one per window):
  claude  C-m (Enter)
  codex   M-Enter (Option+Return)
USAGE
}

die() {
  printf 'cao: %s\n' "$*" >&2
  exit 1
}

need_tmux() {
  command -v tmux >/dev/null 2>&1 || die "tmux is not installed or not on PATH"
}

tmux_has_session() {
  tmux has-session -t "$SESSION" 2>/dev/null
}

ensure_session() {
  need_tmux
  if ! tmux_has_session; then
    tmux new-session -d -s "$SESSION" -n pm
    tmux set-option -t "$SESSION" history-limit "$DEFAULT_HISTORY" >/dev/null
  fi
  local manager
  manager="$(manager_window_id || true)"
  if [[ -n "$manager" ]]; then
    tmux set-option -wqt "$manager" @tmux-autolayout-state "done" 2>/dev/null || true
  fi
}

slug() {
  local raw
  raw="$(basename "$1")"
  raw="${raw//[^[:alnum:]_-]/-}"
  raw="${raw,,}"
  if [[ -z "$raw" ]]; then
    raw="agent"
  fi
  printf '%s\n' "$raw"
}

target_for() {
  local target="$1"
  local resolved=""
  if [[ "$target" == @* ]] || [[ "$target" == %* ]] || [[ "$target" == *:* ]]; then
    printf '%s\n' "$target"
  elif resolved="$(session_window_id "$SESSION" "$target")" && [[ -n "$resolved" ]]; then
    printf '%s\n' "$resolved"
  elif resolved="$(registry_target_for "$target")" && [[ -n "$resolved" ]]; then
    printf '%s\n' "$resolved"
  elif tmux_target_exists "$target"; then
    resolved="$(tmux display-message -p -t "$target" '#{window_id}' 2>/dev/null || true)"
    printf '%s\n' "${resolved:-$target}"
  else
    printf '%s:%s\n' "$SESSION" "$target"
  fi
}

maybe_window_target_for() {
  local target="$1"
  local resolved=""
  target="$(target_for "$target")"
  resolved="$(tmux display-message -p -t "$target" '#{window_id}' 2>/dev/null || true)"
  [[ -n "$resolved" ]] || return 1
  printf '%s\n' "$resolved"
}

window_target_for() {
  local target="$1"
  maybe_window_target_for "$target" || die "tmux target not found: $(target_for "$target")"
}

target_display_name() {
  local target="$1"
  tmux display-message -p -t "$target" '#{session_name}:#{window_name}' 2>/dev/null ||
    printf '%s\n' "$target"
}

state_init() {
  mkdir -p "$STATE_DIR"
  touch "$TARGETS_FILE"
}

registry_upsert() {
  local win_target="$1" runner="$2" name="$3" original_target="$4" tmp
  state_init
  tmp="$(mktemp)"
  awk -F $'\t' -v target="$win_target" '$1 != target' "$TARGETS_FILE" > "$tmp"
  printf '%s\t%s\t%s\t%s\n' "$win_target" "$runner" "$name" "$original_target" >> "$tmp"
  mv "$tmp" "$TARGETS_FILE"
}

registry_remove() {
  local key="$1" tmp
  state_init
  tmp="$(mktemp)"
  awk -F $'\t' -v key="$key" '$1 != key && $3 != key && $4 != key' "$TARGETS_FILE" > "$tmp"
  mv "$tmp" "$TARGETS_FILE"
}

registry_read() {
  [[ -f "$TARGETS_FILE" ]] || return 0
  awk -F $'\t' 'NF >= 2 && $1 != "" { print $0 }' "$TARGETS_FILE"
}

registry_target_for() {
  local key="$1"
  registry_read |
    while IFS=$'\t' read -r win_target _runner name original_target; do
      [[ -n "$win_target" ]] || continue
      if [[ "$key" == "$win_target" || "$key" == "$name" || "$key" == "$original_target" ]]; then
        printf '%s\n' "$win_target"
        return
      fi
      if [[ "$name" == "$key:"* ]]; then
        printf '%s\n' "$win_target"
        return
      fi
    done
}

is_default_session_window_id() {
  local win_target="$1" session_name
  session_name="$(tmux display-message -p -t "$win_target" '#{session_name}' 2>/dev/null || true)"
  [[ -n "$session_name" && "$session_name" == "$SESSION" ]]
}

tmux_target_exists() {
  local target="$1" resolved
  resolved="$(tmux display-message -p -t "$target" '#{window_id}' 2>/dev/null || true)"
  [[ -n "$resolved" ]]
}

session_window_id() {
  local session="$1" window="$2"
  tmux list-windows -t "$session" -F '#{window_name}\t#{window_id}' 2>/dev/null |
    awk -F '\t' -v window="$window" '$1 == window { print $2; found=1; exit } END { exit found ? 0 : 1 }'
}

agent_state() {
  local target="$1" text
  if ! tmux_target_exists "$target"; then
    printf 'missing\n'
    return
  fi

  text="$(tmux capture-pane -J -t "$target" -p -S -120 2>/dev/null | tail -n 35 || true)"
  if grep -Eqi "Working \\(|background terminal running|shell still running|Running |Calling " <<< "$text"; then
    printf 'working\n'
  elif grep -Eqi "usage limit|Conversation interrupted|Reviewing approval request|requires approval" <<< "$text"; then
    printf 'blocked\n'
  elif grep -Eqi "Ready|❯|›" <<< "$text"; then
    printf 'ready\n'
  else
    printf 'idle\n'
  fi
}

context_used_percent() {
  local target="$1" text match pct
  text="$(tmux capture-pane -J -t "$target" -p -S -80 2>/dev/null || true)"
  match="$(grep -Eo '[0-9]{1,3}%[[:space:]]+context[[:space:]]+used' <<< "$text" | tail -n 1 || true)"
  [[ -n "$match" ]] || return 1
  pct="${match%%\%*}"
  [[ "$pct" =~ ^[0-9]+$ ]] || return 1
  if (( pct > 100 )); then
    pct=100
  fi
  printf '%s\n' "$pct"
}

pane_is_compacting() {
  local target="$1" text
  text="$(tmux capture-pane -J -t "$target" -p -S -40 2>/dev/null || true)"
  grep -Eqi 'Compacting conversation' <<< "$text"
}

auto_compact_window() {
  local win_target="$1" runner="$2" state="$3"
  [[ "$AUTO_COMPACT" != "0" ]] || return 0
  [[ "$runner" == "claude" || "$runner" == "codex" ]] || return 0
  [[ "$state" == "ready" || "$state" == "idle" ]] || return 0
  tmux_target_exists "$win_target" || return 0
  pane_is_compacting "$win_target" && return 0

  local pct last_at now submit_key
  pct="$(context_used_percent "$win_target" || true)"
  [[ -n "$pct" ]] || return 0
  (( pct > AUTO_COMPACT_THRESHOLD )) || return 0

  now="$(date +%s)"
  last_at="$(tmux show-options -wqv -t "$win_target" @cao_auto_compact_at 2>/dev/null || true)"
  if [[ "$last_at" =~ ^[0-9]+$ ]] && (( now - last_at < AUTO_COMPACT_COOLDOWN )); then
    return 0
  fi

  submit_key="$(runner_submit_key "$runner")"
  tmux set-option -wq -t "$win_target" @cao_auto_compact_at "$now" >/dev/null || true
  tmux set-option -wq -t "$win_target" @cao_auto_compact_pct "$pct" >/dev/null || true
  tmux send-keys -t "$win_target" "/compact" "$submit_key"
}

auto_compact_sweep() {
  [[ "$AUTO_COMPACT" != "0" ]] || return 0
  tmux_has_session || return 0

  tmux list-windows -t "$SESSION" \
    -F '#{window_id}|#{@cao_runner}' 2>/dev/null |
    while IFS='|' read -r win_id runner; do
      [[ -n "$win_id" ]] || continue
      is_manager_window_id "$win_id" && continue
      [[ -n "$runner" ]] || continue
      auto_compact_window "$win_id" "$runner" "$(agent_state "$win_id")"
    done

  registry_read |
    while IFS=$'\t' read -r win_target runner _name _original_target; do
      [[ -n "$win_target" ]] || continue
      is_default_session_window_id "$win_target" && continue
      tmux_target_exists "$win_target" || continue
      auto_compact_window "$win_target" "$runner" "$(agent_state "$win_target")"
    done
}

dashboard_pane() {
  tmux show-options -qv -t "$SESSION" @cao_dashboard_pane 2>/dev/null || true
}

manager_window_id() {
  local configured current session_name win_id first
  configured="$(tmux show-options -qv -t "$SESSION" @cao_manager_window 2>/dev/null || true)"
  if [[ -n "$configured" ]] && tmux_target_exists "$configured"; then
    session_name="$(tmux display-message -p -t "$configured" '#{session_name}' 2>/dev/null || true)"
    if [[ "$session_name" == "$SESSION" ]]; then
      printf '%s\n' "$configured"
      return
    fi
  fi

  if [[ -n "${TMUX:-}" ]]; then
    current="$(tmux display-message -p '#{session_name}|#{window_id}' 2>/dev/null || true)"
    session_name="${current%%|*}"
    win_id="${current#*|}"
    if [[ -n "$current" && "$current" == *"|"* && "$session_name" == "$SESSION" && -n "$win_id" ]]; then
      tmux set-option -q -t "$SESSION" @cao_manager_window "$win_id" >/dev/null
      printf '%s\n' "$win_id"
      return
    fi
  fi

  if tmux_target_exists "$SESSION:pm"; then
    win_id="$(tmux display-message -p -t "$SESSION:pm" '#{window_id}' 2>/dev/null || true)"
    if [[ -n "$win_id" ]]; then
      tmux set-option -q -t "$SESSION" @cao_manager_window "$win_id" >/dev/null
      printf '%s\n' "$win_id"
      return
    fi
  fi

  first="$(tmux list-windows -t "$SESSION" -F '#{window_id}' 2>/dev/null | head -n 1 || true)"
  if [[ -n "$first" ]]; then
    tmux set-option -q -t "$SESSION" @cao_manager_window "$first" >/dev/null
    printf '%s\n' "$first"
  fi
}

is_manager_window_id() {
  local win_target="$1" manager
  manager="$(manager_window_id || true)"
  [[ -n "$manager" && "$win_target" == "$manager" ]]
}

dashboard_running() {
  local pane
  pane="$(dashboard_pane)"
  [[ -n "$pane" ]] && tmux display-message -p -t "$pane" '#{pane_id}' >/dev/null 2>&1
}

ensure_dashboard() {
  need_tmux
  tmux_has_session || return 0
  dashboard_running && return 0

  local manager main_pane dash_pane cmd q_session q_state_dir q_targets_file q_width q_script
  manager="$(manager_window_id || true)"
  [[ -n "$manager" ]] || return 0
  main_pane="$(tmux list-panes -t "$manager" -F '#{pane_id} #{pane_active}' 2>/dev/null | awk '$2 == 1 { print $1; exit }')"
  if [[ -z "$main_pane" ]]; then
    main_pane="$(tmux display-message -p -t "$manager" '#{pane_id}' 2>/dev/null || true)"
  fi
  [[ -n "$main_pane" ]] || return 0
  printf -v q_session '%q' "$SESSION"
  printf -v q_state_dir '%q' "$STATE_DIR"
  printf -v q_targets_file '%q' "$TARGETS_FILE"
  printf -v q_width '%q' "$DASHBOARD_WIDTH"
  printf -v q_script '%q' "$SCRIPT_PATH"
  cmd="CAO_SESSION=$q_session CAO_STATE_DIR=$q_state_dir CAO_TARGETS_FILE=$q_targets_file CAO_DASHBOARD_WIDTH=$q_width exec $q_script _dashboard_loop"
  dash_pane="$(tmux split-window -h -b -l "$DASHBOARD_WIDTH" -P -F '#{pane_id}' -t "$main_pane" "$cmd" 2>/dev/null || true)"
  if [[ -n "$dash_pane" ]]; then
    tmux set-option -q -t "$SESSION" @cao_dashboard_pane "$dash_pane" >/dev/null
    tmux select-pane -t "$main_pane" 2>/dev/null || true
  fi
}

stop_dashboard() {
  need_tmux
  local pane
  pane="$(dashboard_pane)"
  if [[ -n "$pane" ]]; then
    tmux kill-pane -t "$pane" 2>/dev/null || true
  fi
  tmux set-option -qu -t "$SESSION" @cao_dashboard_pane 2>/dev/null || true
}

status_rows() {
  tmux list-windows -t "$SESSION" \
    -F '#{window_id}|#{window_name}|#{@cao_runner}|#{?window_active,active,}' 2>/dev/null |
    while IFS='|' read -r win_id name runner _active; do
      [[ -n "$win_id" ]] || continue
      if is_manager_window_id "$win_id"; then
        continue
      fi
      printf '%s:%s\t%s\t%s\n' "$SESSION" "$name" "${runner:-?}" "$(agent_state "$win_id")"
    done

  registry_read |
    while IFS=$'\t' read -r win_target runner name _original_target; do
      [[ -n "$win_target" ]] || continue
      if is_default_session_window_id "$win_target"; then
        continue
      fi
      printf '%s\t%s\t%s\n' "$(target_display_name "$win_target")" "$runner" "$(agent_state "$win_target")"
    done
}

dashboard_loop() {
  local esc reset bold dim green yellow red cyan
  esc="$(printf '\033')"
  reset="${esc}[0m"
  bold="${esc}[1m"
  dim="${esc}[2m"
  green="${esc}[32m"
  yellow="${esc}[33m"
  red="${esc}[31m"
  cyan="${esc}[36m"
  printf '%s' "${esc}[?25l"
  trap 'printf "%s" "'"${esc}"'[?25h"' EXIT

  local rows total working ready blocked idle missing name runner state color mark short_name state_label now last_compact_sweep
  last_compact_sweep=0
  while tmux has-session -t "$SESSION" 2>/dev/null; do
    now="$(date +%s)"
    if (( now - last_compact_sweep >= AUTO_COMPACT_INTERVAL )); then
      auto_compact_sweep >/dev/null 2>&1 || true
      last_compact_sweep="$now"
    fi

    rows="$(status_rows || true)"
    total=0
    working=0
    ready=0
    blocked=0
    idle=0
    missing=0
    while IFS=$'\t' read -r _name _runner state; do
      [[ -n "$_name" ]] || continue
      total=$((total + 1))
      case "$state" in
        working) working=$((working + 1)) ;;
        ready) ready=$((ready + 1)) ;;
        blocked) blocked=$((blocked + 1)) ;;
        idle) idle=$((idle + 1)) ;;
        missing) missing=$((missing + 1)) ;;
      esac
    done <<< "$rows"

    printf '%s%s' "${esc}[H" "${esc}[2J"
    printf '%sCAO agents%s\n' "$bold$cyan" "$reset"
    printf '%s%d total w:%d r:%d b:%d i:%d m:%d%s\n' "$dim" "$total" "$working" "$ready" "$blocked" "$idle" "$missing" "$reset"
    if [[ "$total" -eq 0 ]]; then
      printf '%sno workers%s\n' "$dim" "$reset"
    else
      while IFS=$'\t' read -r name runner state; do
        [[ -n "$name" ]] || continue
        case "$state" in
          working) color="$green"; mark="*"; state_label="work" ;;
          ready) color="$yellow"; mark="?"; state_label="ready" ;;
          blocked) color="$red"; mark="!"; state_label="block" ;;
          idle) color="$cyan"; mark="-"; state_label="idle" ;;
          missing) color="$red"; mark="!"; state_label="miss" ;;
          *) color="$yellow"; mark="-"; state_label="$state" ;;
        esac
        short_name="$name"
        if [[ "${#short_name}" -gt 14 ]]; then
          short_name="...${short_name: -11}"
        fi
        printf '%s%s %-14s %-6s %-5s%s\n' "$color" "$mark" "$short_name" "$runner" "$state_label" "$reset"
      done <<< "$rows"
    fi
    sleep 1
  done
}

# ---- Runner abstraction ----------------------------------------------------

runner_validate() {
  case "$1" in
    claude|codex) return 0 ;;
    *) die "unknown runner: $1 (allowed: claude, codex)" ;;
  esac
}

runner_bin() {
  case "$1" in
    claude) printf '%s\n' "$CLAUDE_BIN" ;;
    codex)  printf '%s\n' "$CODEX_BIN" ;;
    *)      die "unknown runner: $1" ;;
  esac
}

runner_submit_key() {
  case "$1" in
    claude) printf 'Enter\n' ;;
    codex)  printf 'M-Enter\n' ;;
    *)      die "unknown runner: $1" ;;
  esac
}

# Lookup the runner recorded on a tmux window.
window_runner() {
  local win_target="$1"
  local r=""
  r="$(tmux show-options -wqv -t "$win_target" @cao_runner 2>/dev/null || true)"
  printf '%s\n' "$r"
}

require_window_runner() {
  local win_target="$1"
  local r
  r="$(window_runner "$win_target")"
  if [[ -z "$r" ]]; then
    die "runner is not registered for $win_target; run: ./bin/cao register $win_target --runner claude|codex"
  fi
  runner_validate "$r"
  printf '%s\n' "$r"
}

# Build the worker launch command line for a runner. Honors --resume and --prompt.
runner_launch_cmd() {
  local runner="$1" resume="$2" prompt="$3"
  local bin
  bin="$(runner_bin "$runner")"

  case "$runner" in
    claude)
      local cmd="$bin --dangerously-skip-permissions"
      if [[ "$resume" == "1" ]]; then
        cmd="$cmd --resume"
      fi
      if [[ -n "$prompt" ]]; then
        local q
        printf -v q '%q' "$prompt"
        cmd="$cmd $q"
      fi
      printf '%s\n' "$cmd"
      ;;
    codex)
      printf '%s\n' "$bin"
      ;;
  esac
}

# ---- Argument parsing helper ----------------------------------------------

parse_global_session_arg() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --session)
        [[ $# -ge 2 ]] || die "--session requires a name"
        SESSION="$2"
        shift 2
        ;;
      *)
        die "unknown option: $1"
        ;;
    esac
  done
}

# ---- Commands --------------------------------------------------------------

cmd_init() {
  parse_global_session_arg "$@"
  ensure_session
  ensure_dashboard
  printf 'CAO tmux session ready: %s\n' "$SESSION"
}

cmd_add() {
  local dir="" name="" resume="0" prompt="" runner="$CAO_RUNNER"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --runner)
        [[ $# -ge 2 ]] || die "--runner requires claude|codex"
        runner="$2"
        shift 2
        ;;
      --name)
        [[ $# -ge 2 ]] || die "--name requires a value"
        name="$2"
        shift 2
        ;;
      --resume)
        resume="1"
        shift
        ;;
      --prompt)
        [[ $# -ge 2 ]] || die "--prompt requires text"
        prompt="$2"
        shift 2
        ;;
      --session)
        [[ $# -ge 2 ]] || die "--session requires a name"
        SESSION="$2"
        shift 2
        ;;
      -*)
        die "unknown option: $1"
        ;;
      *)
        if [[ -n "$dir" ]]; then
          die "only one directory can be supplied"
        fi
        dir="$1"
        shift
        ;;
    esac
  done

  runner_validate "$runner"
  [[ -n "$dir" ]] || die "directory is required"
  [[ -d "$dir" ]] || die "directory does not exist: $dir"

  dir="$(cd "$dir" && pwd)"
  if [[ -z "$name" ]]; then
    name="$(slug "$dir")"
  fi

  ensure_session
  ensure_dashboard
  tmux new-window -d -t "$SESSION" -n "$name" -c "$dir"
  tmux set-option -wqt "$SESSION:$name" @tmux-autolayout-state "done" 2>/dev/null || true
  tmux set-option -w -t "$SESSION:$name" @cao_runner "$runner" >/dev/null

  local launch
  launch="$(runner_launch_cmd "$runner" "$resume" "$prompt")"
  tmux send-keys -t "$SESSION:$name" "$launch" C-m

  # Codex worker: it does not accept arguments, so deliver /resume and prompt
  # after launch using its submit key. Claude already got everything via argv.
  if [[ "$runner" == "codex" ]]; then
    if [[ "$resume" == "1" ]]; then
      sleep 0.5
      tmux send-keys -t "$SESSION:$name" "/resume" M-Enter
    fi
    if [[ -n "$prompt" ]]; then
      sleep 0.5
      tmux send-keys -t "$SESSION:$name" "$prompt" M-Enter
    fi
  fi

  printf 'Added agent window: %s:%s runner=%s cwd=%s\n' "$SESSION" "$name" "$runner" "$dir"
}

cmd_register() {
  local target="" runner=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --runner)
        [[ $# -ge 2 ]] || die "--runner requires claude|codex"
        runner="$2"
        shift 2
        ;;
      --session)
        [[ $# -ge 2 ]] || die "--session requires a name"
        SESSION="$2"
        shift 2
        ;;
      -*)
        die "unknown option: $1"
        ;;
      *)
        if [[ -n "$target" ]]; then
          die "only one target can be supplied"
        fi
        target="$1"
        shift
        ;;
    esac
  done

  [[ -n "$target" ]] || die "target is required"
  [[ -n "$runner" ]] || die "--runner claude|codex is required"
  runner_validate "$runner"
  need_tmux

  local win_target
  win_target="$(window_target_for "$target")"
  tmux display-message -p -t "$win_target" '#{window_id}' >/dev/null
  tmux set-option -w -t "$win_target" @cao_runner "$runner" >/dev/null
  registry_upsert "$win_target" "$runner" "$(target_display_name "$win_target")" "$(target_for "$target")"
  ensure_dashboard
  printf 'Registered target: %s runner=%s\n' "$win_target" "$runner"
}

cmd_unregister() {
  local target=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --session)
        [[ $# -ge 2 ]] || die "--session requires a name"
        SESSION="$2"
        shift 2
        ;;
      -*)
        die "unknown option: $1"
        ;;
      *)
        if [[ -n "$target" ]]; then
          die "only one target can be supplied"
        fi
        target="$1"
        shift
        ;;
    esac
  done

  [[ -n "$target" ]] || die "target is required"
  need_tmux

  local key win_target=""
  key="$(target_for "$target")"
  win_target="$(maybe_window_target_for "$target" || true)"
  if [[ -n "$win_target" ]]; then
    tmux set-option -wu -t "$win_target" @cao_runner 2>/dev/null || true
    registry_remove "$win_target"
    registry_remove "$key"
    printf 'Unregistered target: %s\n' "$win_target"
  else
    registry_remove "$key"
    printf 'Unregistered target: %s\n' "$key"
  fi
  ensure_dashboard
}

cmd_list() {
  parse_global_session_arg "$@"
  need_tmux
  local manager=""
  manager="$(manager_window_id || true)"
  printf '%-4s %-28s %-7s %s\n' '#' 'TARGET' 'RUNNER' 'STATE'
  if tmux_has_session; then
    tmux list-windows -t "$SESSION" \
      -F '#{window_index}|#{window_id}|#{window_name}|#{@cao_runner}|#{?window_active,active,}' |
      while IFS='|' read -r index win_id name runner _active; do
        [[ -n "$win_id" ]] || continue
        if [[ -n "$manager" && "$win_id" == "$manager" ]]; then
          continue
        fi
        printf '%-4s %-28s %-7s %s\n' "$index" "$SESSION:$name" "${runner:-?}" "$(agent_state "$win_id")"
      done
  fi

  registry_read |
    while IFS=$'\t' read -r win_target runner name _original_target; do
      [[ -n "$win_target" ]] || continue
      if is_default_session_window_id "$win_target"; then
        continue
      fi
      if tmux_target_exists "$win_target"; then
        local current_name state
        current_name="$(target_display_name "$win_target")"
        state="$(agent_state "$win_target")"
        printf '%-4s %-28s %-7s %s\n' '*' "$current_name" "$runner" "$state"
      else
        printf '%-4s %-28s %-7s %s\n' '!' "${name:-$win_target}" "$runner" "missing"
      fi
    done
}

cmd_capture() {
  local target="" lines="120"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --lines)
        [[ $# -ge 2 ]] || die "--lines requires a number"
        lines="$2"
        shift 2
        ;;
      --session)
        [[ $# -ge 2 ]] || die "--session requires a name"
        SESSION="$2"
        shift 2
        ;;
      -*)
        die "unknown option: $1"
        ;;
      *)
        if [[ -n "$target" ]]; then
          die "only one target can be supplied"
        fi
        target="$1"
        shift
        ;;
    esac
  done

  need_tmux
  if [[ -z "$target" ]]; then
    local manager=""
    manager="$(manager_window_id || true)"
    if tmux_has_session; then
      tmux list-windows -t "$SESSION" -F '#{window_id}|#{window_name}' |
        while IFS='|' read -r win_id window; do
          [[ -n "$win_id" ]] || continue
          if [[ -n "$manager" && "$win_id" == "$manager" ]]; then
            continue
          fi
          printf '\n===== %s:%s =====\n' "$SESSION" "$window"
          tmux capture-pane -t "$SESSION:$window" -p -S "-$lines"
        done
    fi
    registry_read |
      while IFS=$'\t' read -r win_target _runner name _original_target; do
        [[ -n "$win_target" ]] || continue
        if is_default_session_window_id "$win_target"; then
          continue
        fi
        if tmux_target_exists "$win_target"; then
          printf '\n===== %s =====\n' "$(target_display_name "$win_target")"
          tmux capture-pane -t "$win_target" -p -S "-$lines"
        else
          printf '\n===== %s =====\nmissing target: %s\n' "${name:-$win_target}" "$win_target"
        fi
      done
  else
    tmux capture-pane -t "$(target_for "$target")" -p -S "-$lines"
  fi
}

cmd_send() {
  local target="" text="" enter="1"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --enter)
        enter="1"
        shift
        ;;
      --no-enter)
        enter="0"
        shift
        ;;
      --session)
        [[ $# -ge 2 ]] || die "--session requires a name"
        SESSION="$2"
        shift 2
        ;;
      -*)
        die "unknown option: $1"
        ;;
      *)
        if [[ -z "$target" ]]; then
          target="$1"
        elif [[ -z "$text" ]]; then
          text="$1"
        else
          die "send accepts one target and one text argument"
        fi
        shift
        ;;
    esac
  done

  [[ -n "$target" ]] || die "target is required"
  [[ -n "$text" ]] || die "text is required"
  need_tmux

  local full_target win_target runner submit_key
  full_target="$(target_for "$target")"
  win_target="$(window_target_for "$target")"
  runner="$(require_window_runner "$win_target")"
  submit_key="$(runner_submit_key "$runner")"

  if [[ "$enter" == "1" ]]; then
    tmux send-keys -t "$full_target" "$text" "$submit_key"
  else
    tmux send-keys -t "$full_target" "$text"
  fi
}

cmd_attach() {
  parse_global_session_arg "$@"
  ensure_session
  ensure_dashboard
  tmux attach -t "$SESSION"
}

cmd_kill() {
  parse_global_session_arg "$@"
  need_tmux
  if tmux_has_session; then
    tmux kill-session -t "$SESSION"
    printf 'Killed CAO tmux session: %s\n' "$SESSION"
  else
    printf 'No CAO tmux session found: %s\n' "$SESSION"
  fi
}

main() {
  local cmd="${1:-}"
  if [[ $# -gt 0 ]]; then
    shift
  fi

  case "$cmd" in
    init) cmd_init "$@" ;;
    add) cmd_add "$@" ;;
    register) cmd_register "$@" ;;
    unregister) cmd_unregister "$@" ;;
    list) cmd_list "$@" ;;
    capture) cmd_capture "$@" ;;
    send) cmd_send "$@" ;;
    attach) cmd_attach "$@" ;;
    kill) cmd_kill "$@" ;;
    _dashboard_loop) dashboard_loop ;;
    -h|--help|help|"") usage ;;
    *) die "unknown command: $cmd" ;;
  esac
}

main "$@"
