#!/usr/bin/env bash
set -euo pipefail

SESSION="${CAO_SESSION:-cao}"
CODEX_BIN="${CODEX_BIN:-codex}"
DEFAULT_HISTORY="${CAO_HISTORY:-4000}"

usage() {
  cat <<'USAGE'
Usage:
  cao init [--session NAME]
  cao add DIRECTORY [--name NAME] [--resume] [--prompt TEXT] [--session NAME]
  cao list [--session NAME]
  cao capture [TARGET] [--lines N] [--session NAME]
  cao send TARGET TEXT [--enter|--no-enter] [--session NAME]
  cao attach [--session NAME]
  cao kill [--session NAME]

Targets are tmux targets such as:
  agent-a
  cao:agent-a
  cao:agent-a.0

Environment:
  CAO_SESSION   tmux session name, default: cao
  CODEX_BIN     Codex command, default: codex
  CAO_HISTORY   capture-pane history lines, default: 4000
USAGE
}

die() {
  printf 'cao: %s\n' "$*" >&2
  exit 1
}

need_tmux() {
  command -v tmux >/dev/null 2>&1 || die "tmux is not installed or not on PATH"
}

tmux_has_session() {
  tmux has-session -t "$SESSION" 2>/dev/null
}

ensure_session() {
  need_tmux
  if ! tmux_has_session; then
    tmux new-session -d -s "$SESSION" -n pm
    tmux set-option -t "$SESSION" history-limit "$DEFAULT_HISTORY" >/dev/null
  fi
}

slug() {
  local raw
  raw="$(basename "$1")"
  raw="${raw//[^[:alnum:]_-]/-}"
  raw="${raw,,}"
  if [[ -z "$raw" ]]; then
    raw="agent"
  fi
  printf '%s\n' "$raw"
}

target_for() {
  local target="$1"
  if [[ "$target" == *:* ]]; then
    printf '%s\n' "$target"
  else
    printf '%s:%s\n' "$SESSION" "$target"
  fi
}

parse_global_session_arg() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --session)
        [[ $# -ge 2 ]] || die "--session requires a name"
        SESSION="$2"
        shift 2
        ;;
      *)
        die "unknown option: $1"
        ;;
    esac
  done
}

cmd_init() {
  parse_global_session_arg "$@"
  ensure_session
  printf 'CAO tmux session ready: %s\n' "$SESSION"
}

cmd_add() {
  local dir="" name="" resume="0" prompt=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)
        [[ $# -ge 2 ]] || die "--name requires a value"
        name="$2"
        shift 2
        ;;
      --resume)
        resume="1"
        shift
        ;;
      --prompt)
        [[ $# -ge 2 ]] || die "--prompt requires text"
        prompt="$2"
        shift 2
        ;;
      --session)
        [[ $# -ge 2 ]] || die "--session requires a name"
        SESSION="$2"
        shift 2
        ;;
      -*)
        die "unknown option: $1"
        ;;
      *)
        if [[ -n "$dir" ]]; then
          die "only one directory can be supplied"
        fi
        dir="$1"
        shift
        ;;
    esac
  done

  [[ -n "$dir" ]] || die "directory is required"
  [[ -d "$dir" ]] || die "directory does not exist: $dir"

  dir="$(cd "$dir" && pwd)"
  if [[ -z "$name" ]]; then
    name="$(slug "$dir")"
  fi

  ensure_session
  tmux new-window -t "$SESSION" -n "$name" -c "$dir"
  tmux send-keys -t "$SESSION:$name" "$CODEX_BIN" C-m

  if [[ "$resume" == "1" ]]; then
    sleep 0.5
    tmux send-keys -t "$SESSION:$name" "/resume" C-m
  fi

  if [[ -n "$prompt" ]]; then
    sleep 0.5
    tmux send-keys -t "$SESSION:$name" "$prompt" C-m
  fi

  printf 'Added agent window: %s:%s cwd=%s\n' "$SESSION" "$name" "$dir"
}

cmd_list() {
  parse_global_session_arg "$@"
  ensure_session
  tmux list-windows -t "$SESSION" -F '#{window_index}: #{window_name} #{?window_active,(active),}'
}

cmd_capture() {
  local target="" lines="120"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --lines)
        [[ $# -ge 2 ]] || die "--lines requires a number"
        lines="$2"
        shift 2
        ;;
      --session)
        [[ $# -ge 2 ]] || die "--session requires a name"
        SESSION="$2"
        shift 2
        ;;
      -*)
        die "unknown option: $1"
        ;;
      *)
        if [[ -n "$target" ]]; then
          die "only one target can be supplied"
        fi
        target="$1"
        shift
        ;;
    esac
  done

  ensure_session
  if [[ -z "$target" ]]; then
    tmux list-windows -t "$SESSION" -F '#{window_name}' |
      while IFS= read -r window; do
        printf '\n===== %s:%s =====\n' "$SESSION" "$window"
        tmux capture-pane -t "$SESSION:$window" -p -S "-$lines"
      done
  else
    tmux capture-pane -t "$(target_for "$target")" -p -S "-$lines"
  fi
}

cmd_send() {
  local target="" text="" enter="1"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --enter)
        enter="1"
        shift
        ;;
      --no-enter)
        enter="0"
        shift
        ;;
      --session)
        [[ $# -ge 2 ]] || die "--session requires a name"
        SESSION="$2"
        shift 2
        ;;
      -*)
        die "unknown option: $1"
        ;;
      *)
        if [[ -z "$target" ]]; then
          target="$1"
        elif [[ -z "$text" ]]; then
          text="$1"
        else
          die "send accepts one target and one text argument"
        fi
        shift
        ;;
    esac
  done

  [[ -n "$target" ]] || die "target is required"
  [[ -n "$text" ]] || die "text is required"
  ensure_session
  if [[ "$enter" == "1" ]]; then
    tmux send-keys -t "$(target_for "$target")" "$text" C-m
  else
    tmux send-keys -t "$(target_for "$target")" "$text"
  fi
}

cmd_attach() {
  parse_global_session_arg "$@"
  ensure_session
  tmux attach -t "$SESSION"
}

cmd_kill() {
  parse_global_session_arg "$@"
  need_tmux
  if tmux_has_session; then
    tmux kill-session -t "$SESSION"
    printf 'Killed CAO tmux session: %s\n' "$SESSION"
  else
    printf 'No CAO tmux session found: %s\n' "$SESSION"
  fi
}

main() {
  local cmd="${1:-}"
  if [[ $# -gt 0 ]]; then
    shift
  fi

  case "$cmd" in
    init) cmd_init "$@" ;;
    add) cmd_add "$@" ;;
    list) cmd_list "$@" ;;
    capture) cmd_capture "$@" ;;
    send) cmd_send "$@" ;;
    attach) cmd_attach "$@" ;;
    kill) cmd_kill "$@" ;;
    -h|--help|help|"") usage ;;
    *) die "unknown command: $cmd" ;;
  esac
}

main "$@"
